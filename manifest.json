{
  "manifest_version": 3,
  "name": "동식이는 리트윗을 청소해",
  "version": "0.1.0",
  "description": "현재 열린 X 페이지에서 리트윗 취소 버튼을 찾아 하나씩 취소합니다.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "리트윗 청소"
  }
}